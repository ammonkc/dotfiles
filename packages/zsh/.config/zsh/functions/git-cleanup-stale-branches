# Delete local branches whose upstream was removed on the remote (after fetch -p).
# Only deletes branches that are fully merged into HEAD (git branch -d).
#
# Usage:
#   git-cleanup-stale-branches           # delete stale branches
#   git-cleanup-stale-branches -n        # dry-run (print only)
#
# Extra protected names (space-separated): GIT_CLEANUP_PROTECTED_BRANCHES="release hotfix"

git-cleanup-stale-branches() {
  emulate -L zsh
  setopt localoptions extendedglob

  local dry_run=false
  local -a protected_branches
  protected_branches=(main master develop development staging production trunk)

  if [[ -n "$GIT_CLEANUP_PROTECTED_BRANCHES" ]]; then
    protected_branches+=(${=GIT_CLEANUP_PROTECTED_BRANCHES})
  fi

  while [[ $# -gt 0 ]]; do
    case $1 in
      -n | --dry-run) dry_run=true; shift ;;
      -h | --help)
        print -r -- "Usage: git-cleanup-stale-branches [-n|--dry-run]"
        print -r -- "  Deletes merged local branches whose upstream remote branch is gone."
        return 0
        ;;
      *)
        print -u2 -r -- "Unknown option: $1 (try --help)"
        return 1
        ;;
    esac
  done

  git rev-parse --git-dir >/dev/null 2>&1 || {
    print -u2 -r -- "Not a git repository"
    return 1
  }

  git fetch -p --quiet || return $?

  local current_branch=""
  current_branch=$(git symbolic-ref --short HEAD 2>/dev/null) || true

  local branch upstream_track
  local -a to_delete=()

  while IFS='|' read -r branch upstream_track; do
    [[ -z "$branch" || "$upstream_track" != "[gone]" ]] && continue
    (( ${protected_branches[(Ie)$branch]} )) && continue
    [[ -n "$current_branch" && "$branch" == "$current_branch" ]] && continue
    to_delete+=("$branch")
  done < <(git for-each-ref --format='%(refname:short)|%(upstream:track)' refs/heads)

  if (( ${#to_delete} == 0 )); then
    print -r -- "No stale local branches to delete."
    return 0
  fi

  local deleted=0 skipped=0

  for branch in "${to_delete[@]}"; do
    if $dry_run; then
      print -r -- "would delete: $branch"
      ((deleted++))
      continue
    fi

    if git branch -d "$branch" >/dev/null 2>&1; then
      print -r -- "deleted: $branch"
      ((deleted++))
    else
      print -u2 -r -- "skipped (not fully merged): $branch"
      ((skipped++))
    fi
  done

  if ! $dry_run; then
    print -r -- "Done: ${deleted} deleted, ${skipped} skipped."
  fi
}
